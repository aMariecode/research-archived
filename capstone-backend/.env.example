# Backend environment variables example
# Copy this file to .env and fill in your values

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/ua-research-archive

# JWT secret for authentication
JWT_SECRET=your_jwt_secret_here

# reCAPTCHA secret key (for backend verification)
RECAPTCHA_SECRET=your_recaptcha_secret_here

# Cloudinary or other file storage config (if used)
CLOUDINARY_URL=your_cloudinary_url_here

# Frontend URL for CORS (set to your local frontend for dev, Vercel URL for prod)
FRONTEND_URL=http://localhost:4000

# Port to run the backend server
PORT=4000
